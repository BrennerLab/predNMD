#!/usr/bin/env python3

"""
Filter VCF to keep only variants in protein-coding exons using bedtools.
Works with both GENCODE and Ensembl GTF files or pre-made BED files.
Use --gene to filter for a specific gene
"""

import argparse
import subprocess
import sys
import os
import gzip
from pathlib import Path


def parse_gtf_line(line):
    """Parse a GTF line and extract relevant information."""
    if line.startswith('#'):
        return None
    
    fields = line.strip().split('\t')
    if len(fields) < 9:
        return None
    
    chrom = fields[0]
    feature = fields[2]
    start = int(fields[3])
    end = int(fields[4])
    attributes = fields[8]
    
    return {
        'chrom': chrom,
        'feature': feature,
        'start': start,
        'end': end,
        'attributes': attributes
    }


def extract_attribute(attributes, key):
    """Extract attribute value from GTF attributes string."""
    for attr in attributes.split(';'):
        attr = attr.strip()
        if attr.startswith(key):
            value = attr.split(' ', 1)[1].strip()
            value = value.strip('"\'')
            return value
    return None


def is_protein_coding_gene(attributes, gtf_source):
    """Check if a gene is protein-coding based on GTF source."""
    if gtf_source.lower() == 'gencode':
        gene_type = extract_attribute(attributes, 'gene_type')
        if not gene_type:
            gene_type = extract_attribute(attributes, 'gene_biotype')
        return gene_type == 'protein_coding'
    elif gtf_source.lower() == 'ensembl':
        gene_biotype = extract_attribute(attributes, 'gene_biotype')
        return gene_biotype == 'protein_coding'
    else:
        gene_type = extract_attribute(attributes, 'gene_type')
        gene_biotype = extract_attribute(attributes, 'gene_biotype')
        return (gene_type == 'protein_coding' or gene_biotype == 'protein_coding')


def matches_gene_filter(attributes, gene_filter):
    """Check if gene matches the filter (by name or ID)."""
    if not gene_filter:
        return True
    
    gene_name = extract_attribute(attributes, 'gene_name')
    gene_id = extract_attribute(attributes, 'gene_id')
    
    return (gene_name == gene_filter or gene_id == gene_filter)


def create_protein_coding_bed(gtf_file, output_bed, gtf_source='auto', gene_filter=None):
    """Create BED file of protein-coding exon coordinates from GTF.
    
    Args:
        gtf_file: Path to GTF file
        output_bed: Output BED file path
        gtf_source: GTF source (gencode/ensembl/auto)
        gene_filter: Optional gene name or Ensembl ID to filter for
    """
    if gene_filter:
        print(f"Creating protein-coding exons BED file from {gtf_file} (filtering for gene: {gene_filter})")
    else:
        print(f"Creating protein-coding exons BED file from {gtf_file}")
    
    # Auto-detect GTF source
    if gtf_source == 'auto':
        if 'gencode' in str(gtf_file).lower():
            gtf_source = 'gencode'
        elif 'ensembl' in str(gtf_file).lower():
            gtf_source = 'ensembl'
        else:
            gtf_source = 'unknown'
            print("Warning: Could not auto-detect GTF source. Trying both patterns.")
    
    print(f"Detected GTF source: {gtf_source}")
    
    # First pass: identify protein-coding genes (and optionally filter by gene name)
    print("Pass 1: Identifying protein-coding genes...")
    protein_coding_genes = set()
    gene_found = False if gene_filter else True  # Track if gene filter matched
    
    if str(gtf_file).endswith('.gz'):
        file_handle = gzip.open(gtf_file, 'rt')
    else:
        file_handle = open(gtf_file, 'r')
    
    try:
        for line_num, line in enumerate(file_handle, 1):
            if line_num % 100000 == 0:
                print(f"Pass 1 - Processed {line_num} lines...")
            
            parsed = parse_gtf_line(line)
            if not parsed or parsed['feature'] != 'gene':
                continue
            
            # Check if protein-coding
            if not is_protein_coding_gene(parsed['attributes'], gtf_source):
                continue
            
            # Check if matches gene filter (if specified)
            if gene_filter and not matches_gene_filter(parsed['attributes'], gene_filter):
                continue
            
            gene_id = extract_attribute(parsed['attributes'], 'gene_id')
            if gene_id:
                protein_coding_genes.add(gene_id)
                if gene_filter:
                    gene_found = True
                    gene_name = extract_attribute(parsed['attributes'], 'gene_name')
                    print(f"Found target gene: {gene_name} ({gene_id})")
    finally:
        file_handle.close()
    
    # Check if gene filter matched anything
    if gene_filter and not gene_found:
        raise ValueError(
            f"Gene '{gene_filter}' not found in GTF file.\n"
            f"Please check:\n"
            f"  1. Gene name spelling (case-sensitive)\n"
            f"  2. Try Ensembl ID instead (e.g., ENSG00000012048 for BRCA1)\n"
            f"  3. Ensure gene is protein-coding"
        )
    
    print(f"Found {len(protein_coding_genes)} protein-coding gene(s)")
    
    if len(protein_coding_genes) == 0:
        return 0
    
    # Second pass: extract exons from protein-coding genes
    print("Pass 2: Extracting exons from protein-coding gene(s)...")
    protein_coding_exons = []
    
    if str(gtf_file).endswith('.gz'):
        file_handle = gzip.open(gtf_file, 'rt')
    else:
        file_handle = open(gtf_file, 'r')
    
    try:
        for line_num, line in enumerate(file_handle, 1):
            if line_num % 100000 == 0:
                print(f"Pass 2 - Processed {line_num} lines...")
            
            parsed = parse_gtf_line(line)
            if not parsed or parsed['feature'] != 'exon':
                continue
            
            gene_id = extract_attribute(parsed['attributes'], 'gene_id')
            if gene_id and gene_id in protein_coding_genes:
                bed_start = parsed['start'] - 1  # Convert to 0-based
                bed_end = parsed['end']
                
                gene_name = (extract_attribute(parsed['attributes'], 'gene_name') or
                           extract_attribute(parsed['attributes'], 'gene_id') or
                           'unknown')
                transcript_id = (extract_attribute(parsed['attributes'], 'transcript_id') or
                               'unknown')
                exon_number = (extract_attribute(parsed['attributes'], 'exon_number') or
                             'unknown')
                
                protein_coding_exons.append((
                    parsed['chrom'],
                    bed_start,
                    bed_end,
                    gene_name,
                    transcript_id,
                    exon_number
                ))
    finally:
        file_handle.close()
    
    # Sort by chromosome and position
    def sort_key(exon):
        chrom, start = exon[0], exon[1]
        if chrom.startswith('chr'):
            chrom_clean = chrom[3:]
        else:
            chrom_clean = chrom
        
        if chrom_clean.isdigit():
            return (0, int(chrom_clean), start)
        elif chrom_clean == 'X':
            return (1, 0, start)
        elif chrom_clean == 'Y':
            return (1, 1, start)
        elif chrom_clean == 'M' or chrom_clean == 'MT':
            return (1, 2, start)
        else:
            return (2, chrom_clean, start)
    
    protein_coding_exons.sort(key=sort_key)
    
    # Write BED file
    if gene_filter:
        print(f"Writing {len(protein_coding_exons)} exons from gene {gene_filter} to {output_bed}")
    else:
        print(f"Writing {len(protein_coding_exons)} protein-coding exons to {output_bed}")
    
    with open(output_bed, 'w') as bed_file:
        if gene_filter:
            bed_file.write(f"# Protein-coding exons for gene {gene_filter} extracted from GTF\n")
        else:
            bed_file.write("# Protein-coding exons extracted from GTF\n")
        bed_file.write("# Format: chrom start end gene_name transcript_id exon_number\n")
        for chrom, start, end, gene_name, transcript_id, exon_number in protein_coding_exons:
            bed_file.write(f"{chrom}\t{start}\t{end}\t{gene_name}\t{transcript_id}\t{exon_number}\n")
    
    if gene_filter:
        print(f"Created BED file with {len(protein_coding_exons)} exons from gene {gene_filter}")
    else:
        print(f"Created BED file with {len(protein_coding_exons)} protein-coding exons")
    
    return len(protein_coding_exons)


def filter_vcf_with_bedtools(input_vcf, bed_file, output_vcf, threads=1):
    """
    Filter VCF using bedtools intersect for region filtering.
    """
    print(f"Filtering VCF {input_vcf} using bedtools intersect with BED file {bed_file}")
    
    # Check tools availability
    try:
        subprocess.run(['bedtools', '--version'], capture_output=True, check=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        raise RuntimeError("bedtools not found. Please install bedtools.")
    
    try:
        subprocess.run(['bcftools', '--version'], capture_output=True, check=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        raise RuntimeError("bcftools not found. Please install bcftools.")
    
    # Determine output format
    output_format = 'v'
    if output_vcf.endswith('.gz'):
        output_format = 'z'
    elif output_vcf.endswith('.bcf'):
        output_format = 'b'
    
    # Bedtools intersect for region filtering
    print("Filtering by regions using bedtools intersect...")
    
    region_filtered_vcf = f"{output_vcf}.temp.vcf" if output_format != 'v' else output_vcf
    
    cmd = [
        'bedtools', 'intersect',
        '-a', input_vcf,
        '-b', bed_file,
        '-header',
        '-u'
    ]
    
    print(f"Running: {' '.join(cmd)} > {region_filtered_vcf}")
    
    try:
        with open(region_filtered_vcf, 'w') as outfile:
            subprocess.run(cmd, stdout=outfile, stderr=subprocess.PIPE, text=True, check=True)
        
        print(f"Region-filtered VCF: {region_filtered_vcf}")
        
        if not os.path.exists(region_filtered_vcf) or os.path.getsize(region_filtered_vcf) == 0:
            raise RuntimeError(f"Region-filtered file {region_filtered_vcf} was not created or is empty")
        
        # Count variants
        count_cmd = ['bcftools', 'view', '-H', region_filtered_vcf, '|', 'wc', '-l']
        count_result = subprocess.run(' '.join(count_cmd), shell=True, capture_output=True, text=True)
        if count_result.returncode == 0:
            variant_count = count_result.stdout.strip()
            print(f"Variants after region filtering: {variant_count}")
        
    except subprocess.CalledProcessError as e:
        print(f"Error in bedtools intersect: {e}")
        print(f"STDERR: {e.stderr}")
        raise
    
    # Convert to final output format if needed
    if output_format != 'v':
        print("Converting to final output format...")
        cmd_convert = [
            'bcftools', 'view',
            '-O', output_format,
            '--threads', str(threads),
            '-o', output_vcf,
            region_filtered_vcf
        ]
        subprocess.run(cmd_convert, capture_output=True, text=True, check=True)
        
        try:
            os.remove(region_filtered_vcf)
        except OSError:
            pass
    
    print(f"Successfully filtered VCF. Output saved to {output_vcf}")
    
    # Count final variants
    count_cmd = ['bcftools', 'view', '-H', output_vcf, '|', 'wc', '-l']
    count_result = subprocess.run(' '.join(count_cmd), shell=True, capture_output=True, text=True)
    if count_result.returncode == 0:
        variant_count = count_result.stdout.strip()
        print(f"Final filtered VCF contains {variant_count} variants")


def main():
    parser = argparse.ArgumentParser(
        description="Filter VCF to keep only variants in protein-coding exons (optionally for a specific gene)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Filter for all protein-coding exons
  python filter_vcf.py input.vcf output.vcf --gtf-file annotations.gtf
  
  # Filter for specific gene (faster!)
  python filter_vcf.py input.vcf output.vcf --gtf-file annotations.gtf --gene BRCA1
  python filter_vcf.py input.vcf output.vcf --gtf-file annotations.gtf --gene ENSG00000012048
  
  # Using pre-made BED file (fastest for multiple VCFs)
  python filter_vcf.py input.vcf output.vcf --bed-file protein_coding_exons.bed
  
  # Create BED file once and keep it for reuse
  python filter_vcf.py input1.vcf output1.vcf --gtf-file gencode.gtf --keep-bed --bed-output exons.bed
  python filter_vcf.py input2.vcf output2.vcf --bed-file exons.bed
  
  # Gene-specific analysis workflow
  python filter_vcf.py patient.vcf brca1_filtered.vcf --gtf-file gencode.gtf --gene BRCA1 --keep-bed
  # Then continue with VEP annotation on the much smaller VCF
        """
    )
    
    # Required positional arguments
    parser.add_argument('input_vcf', help='Input VCF file (can be gzipped)')
    parser.add_argument('output_vcf', help='Output filtered VCF file (.vcf, .vcf.gz, or .bcf)')
    
    # GTF or BED input (mutually exclusive)
    input_group = parser.add_mutually_exclusive_group(required=True)
    input_group.add_argument('--gtf-file', help='GTF annotation file (can be gzipped)')
    input_group.add_argument('--bed-file', help='Pre-made BED file with protein-coding exons')
    
    # Gene filtering (NEW!)
    parser.add_argument('--gene', 
                       help='Filter for specific gene (by gene name or Ensembl ID). '
                            'Example: --gene BRCA1 or --gene ENSG00000012048')
    
    # GTF-specific arguments
    parser.add_argument('--gtf-source', choices=['gencode', 'ensembl', 'auto'],
                       default='auto', help='GTF file source (default: auto-detect, only used with --gtf-file)')
    parser.add_argument('--bed-output', help='Output BED file name for protein-coding exons (only used with --gtf-file)')
    parser.add_argument('--keep-bed', action='store_true',
                       help='Keep the intermediate BED file of protein-coding exons (only used with --gtf-file)')
    
    # Technical options
    parser.add_argument('--threads', type=int, default=1,
                       help='Number of threads for bcftools (default: 1)')
    
    args = parser.parse_args()
    
    print("=== VCF Protein-Coding Exon Filter ===")
    print(f"Input VCF: {args.input_vcf}")
    if args.gtf_file:
        print(f"GTF file: {args.gtf_file}")
    else:
        print(f"BED file: {args.bed_file}")
    if args.gene:
        print(f"Gene filter: {args.gene}")
    print(f"Output VCF: {args.output_vcf}")
    print()
    
    # Validate input files
    if not os.path.exists(args.input_vcf):
        print(f"Error: Input VCF file {args.input_vcf} not found")
        sys.exit(1)
    
    if args.gtf_file:
        if not os.path.exists(args.gtf_file):
            print(f"Error: GTF file {args.gtf_file} not found")
            sys.exit(1)
    elif args.bed_file:
        if not os.path.exists(args.bed_file):
            print(f"Error: BED file {args.bed_file} not found")
            sys.exit(1)
        # Check if using --gene with pre-made BED
        if args.gene:
            print("Warning: --gene option ignored when using pre-made BED file")
            print("To filter by gene, use --gtf-file instead of --bed-file")
    
    # Determine BED file to use
    if args.gtf_file:
        if args.bed_output:
            bed_file = args.bed_output
        elif args.gene:
            # Use gene-specific BED name
            bed_file = f"{Path(args.output_vcf).stem}_{args.gene}_exons.bed"
        else:
            bed_file = f"{Path(args.output_vcf).stem}_protein_coding_exons.bed"
        use_existing_bed = False
    else:
        bed_file = args.bed_file
        use_existing_bed = True
    
    try:
        if not use_existing_bed:
            print("Step 1: Creating BED file from GTF...")
            exon_count = create_protein_coding_bed(
                args.gtf_file, 
                bed_file, 
                args.gtf_source,
                args.gene  # Pass gene filter
            )
            
            if exon_count == 0:
                if args.gene:
                    print(f"Error: No exons found for gene '{args.gene}'")
                    print("Check gene name spelling or try Ensembl ID")
                else:
                    print("Warning: No protein-coding exons found in GTF file!")
                    print("Check the GTF format and --gtf-source parameter")
                sys.exit(1)
        else:
            print(f"Step 1: Using existing BED file: {bed_file}")
            try:
                with open(bed_file, 'r') as f:
                    line_count = sum(1 for line in f if not line.startswith('#') and line.strip())
                print(f"BED file contains {line_count} regions")
                if line_count == 0:
                    print("Error: BED file appears to be empty")
                    sys.exit(1)
            except Exception as e:
                print(f"Error reading BED file: {e}")
                sys.exit(1)
        
        # Step 2: Filter VCF using bedtools
        print("Step 2: Filtering VCF...")
        filter_vcf_with_bedtools(
            args.input_vcf,
            bed_file,
            args.output_vcf,
            args.threads
        )
        
        # Clean up temporary BED file if not keeping it
        if not use_existing_bed and not args.keep_bed and not args.bed_output:
            try:
                os.remove(bed_file)
                print(f"Removed temporary BED file {bed_file}")
            except OSError:
                print(f"Warning: Could not remove temporary BED file {bed_file}")
        
        print("\nVCF filtering completed successfully!")
        if args.gene:
            print(f"Filtered for variants in gene {args.gene} (protein-coding exons only)")
        else:
            print(f"Filtered for variants in protein-coding exons")
        
        if not use_existing_bed and (args.keep_bed or args.bed_output):
            print(f"BED file saved as: {bed_file}")
            print(f"You can reuse this BED file with: --bed-file {bed_file}")
        
    except ValueError as e:
        print(f"Error: {e}")
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
